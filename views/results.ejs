<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/results.css">
  <title>Chess Opening Analysis - <%= username %></title>

</head>
<body>
  <div class="container">
    <!-- Header Stats -->

    <div class="header">
      <h1>♟️ Chess Opening Analysis</h1>
               <p style="color:rgb(126, 8, 8) ; font-size: 0.9em; margin-top: 10px;"> Analyzing the last 6 months of games
</p>
      <h2 style="color: #667eea; margin-top: 10px;"><%= username %></h2>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number"><%= totalGames %></div>
          <div class="stat-label">Games Analyzed</div>
        </div>
        <div class="stat-card">
          <div class="stat-number win-rate"><%= winRate %>%</div>
          <div class="stat-label">Win Rate</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" style="color: #4caf50;"><%= totalWins %></div>
          <div class="stat-label">Total Wins</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" style="color: #f44336;"><%= totalLosses %></div>
          <div class="stat-label">Total Losses</div>
        </div>
      </div>
    </div>

    <!-- Losses Section -->
    <div class="section">
      <h2><span class="icon">🎯</span> Openings you Struggled Against</h2>
      <p style="color: #666; margin-bottom: 20px;">Study these openings to improve your defensive skills</p>

      <% if (topLosses.length === 0) { %>
        <div class="no-data">No losses found! You're undefeated! 🏆</div>
      <% } else { %>
        <ul class="opening-list">
          <% topLosses.forEach((opening, index) => { %>
            <li class="opening-item loss-item">
              <span class="rank">#<%= index + 1 %></span>
              <span class="opening-name"><%= opening[0] %></span>
              <span class="count-badge loss-badge"><%= opening[1] %> losses</span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <!-- White Wins Section -->
    <div class="section">
      <h2><span class="icon">⚪</span> Your Best Openings as White</h2>
      <p style="color: #666; margin-bottom: 20px;">
        Total wins as White: <strong><%= winsAsWhite %></strong>
        <% if (topWhiteWins.length > 0 && topWhiteWins[0][0].toLowerCase().includes('Jobava')) { %>
          <span class="highlight">Jobava London spotted! 🎉</span>
        <% } else if (topWhiteWins.length > 0 && topWhiteWins[0][0].toLowerCase().includes('Caro')) { %>
          <span class="highlight">Caro-Kann spotted! 🎉</span>
        <% } %>
      </p>

      <% if (topWhiteWins.length === 0) { %>
        <div class="no-data">No wins as White yet. Keep practicing! 💪</div>
      <% } else { %>
        <ul class="opening-list">
          <% topWhiteWins.forEach((opening, index) => { %>
            <li class="opening-item white-win-item">
              <span class="rank">#<%= index + 1 %></span>
              <span class="opening-name"><%= opening[0] %></span>
              <span class="count-badge white-win-badge"><%= opening[1] %> wins</span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <!-- Black Wins Section -->
    <div class="section">
      <h2><span class="icon">⚫</span> Your Best Openings as Black</h2>
      <p style="color: #666; margin-bottom: 20px;">
        Total wins as Black: <strong><%= winsAsBlack %></strong>
        <% if (topBlackWins.length > 0 && topBlackWins[0][0].toLowerCase().includes('caro')) { %>
          <span class="highlight">Caro-Kann spotted! 🎉</span>
        <% } %>
      </p>

      <% if (topBlackWins.length === 0) { %>
        <div class="no-data">No wins as Black yet. Keep fighting! ⚔️</div>
      <% } else { %>
        <ul class="opening-list">
          <% topBlackWins.forEach((opening, index) => { %>
            <li class="opening-item black-win-item">
              <span class="rank">#<%= index + 1 %></span>
              <span class="opening-name"><%= opening[0] %></span>
              <span class="count-badge black-win-badge"><%= opening[1] %> wins</span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <div style="text-align: center;">
      <a href="/" class="back-button">← Analyze Another Player</a>
    </div>
  </div>

  <!--Footer-->
<footer>
      <div id="footer">
      <span style="color: aqua;">Built by Kamil</span>

      <a href="https://www.instagram.com/iconically_kamil/" target="_blank" class="social">
        <img src="/images/instagram.png" alt="Instagram" class="icon" height="15px" width=" 15px">
        Instagram
      </a>

       <a href="https://github.com/Ymil23" target="_blank">
        <img src="/images/github.png" alt="Instagram" class="icon" height="15px" width=" 15px">
        GitHub
      </a>
    </div>
</footer>

</body>
</html>