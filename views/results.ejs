<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chess Opening Analysis - <%= username %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .header {
      background: white;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      margin-bottom: 30px;
      text-align: center;
    }

    h1 {
      color: #333;
      margin-bottom: 10px;
      font-size: 2.5em;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin: 30px 0;
    }

    .stat-card {
      background: #f5f5f5;
      padding: 25px;
      border-radius: 15px;
      text-align: center;
    }

    .stat-number {
      font-size: 2.5em;
      font-weight: bold;
      color: #667eea;
    }

    .stat-label {
      color: #666;
      font-size: 0.9em;
      margin-top: 10px;
    }

    .win-rate {
      color: #4caf50 !important;
    }

    .section {
      background: white;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      margin-bottom: 30px;
    }

    h2 {
      color: #333;
      margin-bottom: 25px;
      font-size: 1.8em;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .icon {
      font-size: 1.2em;
    }

    .opening-list {
      list-style: none;
    }

    .opening-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px;
      margin-bottom: 12px;
      background: #f9f9f9;
      border-radius: 10px;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .loss-item {
      border-left: 5px solid #f44336;
    }

    .white-win-item {
      border-left: 5px solid #2196f3;
    }

    .black-win-item {
      border-left: 5px solid #4caf50;
    }

    .opening-item:hover {
      transform: translateX(5px);
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .rank {
      font-size: 1.5em;
      font-weight: bold;
      color: #999;
      min-width: 50px;
    }

    .opening-name {
      flex: 1;
      font-weight: 600;
      color: #333;
      margin: 0 20px;
      font-size: 1.1em;
    }

    .count-badge {
      color: white;
      padding: 10px 25px;
      border-radius: 25px;
      font-weight: bold;
      min-width: 90px;
      text-align: center;
      font-size: 1em;
    }

    .loss-badge {
      background: linear-gradient(135deg, #f44336 0%, #e91e63 100%);
    }

    .white-win-badge {
      background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
    }

    .black-win-badge {
      background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
    }

    .back-button {
      display: inline-block;
      margin-top: 20px;
      padding: 15px 30px;
      background: #667eea;
      color: white;
      text-decoration: none;
      border-radius: 10px;
      font-weight: 600;
      transition: transform 0.2s;
    }

    .back-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
    }

    .no-data {
      text-align: center;
      padding: 40px;
      color: #999;
      font-size: 1.1em;
    }

    .highlight {
      background: #fff3cd;
      padding: 3px 8px;
      border-radius: 5px;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header Stats -->

    <div class="header">
      <h1>♟️ Chess Opening Analysis</h1>
               <p style="color:rgb(126, 8, 8) ; font-size: 0.9em; margin-top: 10px;"> Analyzing the last 6 months of games
</p>
      <h2 style="color: #667eea; margin-top: 10px;"><%= username %></h2>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number"><%= totalGames %></div>
          <div class="stat-label">Games Analyzed</div>
        </div>
        <div class="stat-card">
          <div class="stat-number win-rate"><%= winRate %>%</div>
          <div class="stat-label">Win Rate</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" style="color: #4caf50;"><%= totalWins %></div>
          <div class="stat-label">Total Wins</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" style="color: #f44336;"><%= totalLosses %></div>
          <div class="stat-label">Total Losses</div>
        </div>
      </div>
    </div>

    <!-- Losses Section -->
    <div class="section">
      <h2><span class="icon">🎯</span> Openings you Struggled Against</h2>
      <p style="color: #666; margin-bottom: 20px;">Study these openings to improve your defensive skills</p>

      <% if (topLosses.length === 0) { %>
        <div class="no-data">No losses found! You're undefeated! 🏆</div>
      <% } else { %>
        <ul class="opening-list">
          <% topLosses.forEach((opening, index) => { %>
            <li class="opening-item loss-item">
              <span class="rank">#<%= index + 1 %></span>
              <span class="opening-name"><%= opening[0] %></span>
              <span class="count-badge loss-badge"><%= opening[1] %> losses</span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <!-- White Wins Section -->
    <div class="section">
      <h2><span class="icon">⚪</span> Your Best Openings as White</h2>
      <p style="color: #666; margin-bottom: 20px;">
        Total wins as White: <strong><%= winsAsWhite %></strong>
        <% if (topWhiteWins.length > 0 && topWhiteWins[0][0].toLowerCase().includes('london')) { %>
          <span class="highlight">Jobava London spotted! 🎉</span>
        <% } %>
      </p>

      <% if (topWhiteWins.length === 0) { %>
        <div class="no-data">No wins as White yet. Keep practicing! 💪</div>
      <% } else { %>
        <ul class="opening-list">
          <% topWhiteWins.forEach((opening, index) => { %>
            <li class="opening-item white-win-item">
              <span class="rank">#<%= index + 1 %></span>
              <span class="opening-name"><%= opening[0] %></span>
              <span class="count-badge white-win-badge"><%= opening[1] %> wins</span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <!-- Black Wins Section -->
    <div class="section">
      <h2><span class="icon">⚫</span> Your Best Openings as Black</h2>
      <p style="color: #666; margin-bottom: 20px;">
        Total wins as Black: <strong><%= winsAsBlack %></strong>
        <% if (topBlackWins.length > 0 && topBlackWins[0][0].toLowerCase().includes('caro')) { %>
          <span class="highlight">Caro-Kann spotted! 🎉</span>
        <% } %>
      </p>

      <% if (topBlackWins.length === 0) { %>
        <div class="no-data">No wins as Black yet. Keep fighting! ⚔️</div>
      <% } else { %>
        <ul class="opening-list">
          <% topBlackWins.forEach((opening, index) => { %>
            <li class="opening-item black-win-item">
              <span class="rank">#<%= index + 1 %></span>
              <span class="opening-name"><%= opening[0] %></span>
              <span class="count-badge black-win-badge"><%= opening[1] %> wins</span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>

    <div style="text-align: center;">
      <a href="/" class="back-button">← Analyze Another Player</a>
    </div>
  </div>

  <!--Footer-->
<div style="text-align: center; padding: 20px; color: #666; font-size: 0.9em;">
  Built by Kamil | 
  <a href="https://github.com/Ymil23" style="color: #667eea;">GitHub</a>
</div>

</body>
</html>